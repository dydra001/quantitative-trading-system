{
  "manifest_version": 3,
  "name": "TradingView Signal to MT5",
  "version": "3.0",
  "description": "Reads Open signals from Strategy Tester and sends to MT5",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.tradingview.com/*",
    "http://localhost:8080/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.tradingview.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Signal Monitor"
  }
}
